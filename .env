# spring
HIKARI_MAX_POOL_SIZE=20
HIKARI_MIN_POOL_SIZE=5

# hibernate and flyway
DDL_AUTO=update
SHOW_SQL=true
LOG_LEVEL=TRACE
HIBERNATE_FORMAT_SQL=true
FLYWAY_ENABLED=true
FLYWAY_LOCATION=classpath:db/migration
FLYWAY_VALIDATION=true

# postgres
POSTGRES_DB=employee_db
POSTGRES_DB_NAME=postgresql
POSTGRES_USER=postgres
POSTGRES_PASSWORD=admin
POSTGRES_CONTAINER_NAME=postgres
POSTGRES_DRIVER_CLASS=org.postgresql.Driver